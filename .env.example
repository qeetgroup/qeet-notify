# ── Server ────────────────────────────────────────────────────────────────────
HTTP_PORT=8080
ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://qeet-notify:qeet-notify@localhost:5433/qeet-notify?sslmode=disable
MIGRATIONS_DIR=migrations

# ── NATS ──────────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── S3 / MinIO (dev) ──────────────────────────────────────────────────────────
S3_BUCKET=qeet-notify
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-south-1

# ── Qeet ID ───────────────────────────────────────────────────────────────────
QEET_ID_ISSUER=https://api.id.qeet.in
ENCRYPTION_KEY=dev-key-change-in-prod

# ── Email providers ───────────────────────────────────────────────────────────
AWS_SES_REGION=ap-south-1
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
RESEND_API_KEY=

# ── SMS providers ─────────────────────────────────────────────────────────────
MSG91_API_KEY=
TWOFACTOR_API_KEY=

# ── WhatsApp ──────────────────────────────────────────────────────────────────
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_ID=
META_WHATSAPP_VERIFY_TOKEN=

# ── Observability ─────────────────────────────────────────────────────────────
QEET_LOGS_OTLP_ENDPOINT=
