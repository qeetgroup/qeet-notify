# Multi-stage build for the API server binary only.
# Produces a minimal image; use for production API pods.
FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /bin/qeet-notify-server ./cmd/server

FROM gcr.io/distroless/static-debian12
COPY --from=builder /bin/qeet-notify-server /qeet-notify-server
EXPOSE 8080 8082
ENTRYPOINT ["/qeet-notify-server"]
